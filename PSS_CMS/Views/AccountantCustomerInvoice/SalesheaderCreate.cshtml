        function showTab(index) {

            // 🚫 BLOCK WITHOUT VERIFY
            if ((index === 2 || index === 3) && !isCustomerVerified) {
                Swal.fire({
                    icon: "warning",
                    title: "Verification Required",
                    text: "Please verify email to continue"
                });
                return;
            }

            $(".tab-content").removeClass("active");
            $(".tab-content").eq(index).addClass("active");

            $(".tab-buttons button").removeClass("active");
            $(".tab-buttons button").eq(index).addClass("active");
        }
        function showNextTab() {
            const contents = document.querySelectorAll('.tab-content');
            let activeIndex = Array.from(contents).findIndex(c => c.classList.contains('active'));

            if (activeIndex !== -1 && activeIndex < contents.length - 1) {
                showTab(activeIndex + 1);
            }
        }
    </script>
