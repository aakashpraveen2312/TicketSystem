                                        int duration = 0;

                                        if (durationMap != null && !string.IsNullOrEmpty(item.Value))
                                        {
                                            int key = Convert.ToInt32(item.Value);

                                            if (durationMap.ContainsKey(key))
                                            {
                                                duration = durationMap[key];
                                            }
                                        }

                                        <option value="@item.Value"
                                                data-duration="@duration"
                                                @(item.Selected ? "selected" : "")>
                                            @item.Text
                                        </option>
                                    }

                                </select>
                            }
                            else
                            {
                                <p>No product's are available</p>
                            }

