    <script>
$(document).ready(function () {

    function loadAdmins() {

        var precid = $("#SelectedProduct").val();
        var cmprecid = '@Session["CompanyID"]';

        $("#AdminDropdown")
            .prop("disabled", true)
            .empty()
            .append('<option value="">Loading Service Engineer...</option>');

        if (!precid) {
            $("#AdminDropdown")
                .empty()
                .append('<option value="">-- Select Service Engineer --</option>');
            return;
        }

        $.ajax({
            url: '@Url.Action("GetProductAdmins", "AccountantCustomerInvoice")',
            type: 'GET',
            data: {
                cmprecid: cmprecid,
                precid: precid
            },
            success: function (res) {

                console.log("API response:", res);

                $("#AdminDropdown").empty();

                if (res.status === "Y" && res.data && res.data.length > 0) {

                    $("#AdminDropdown")
                        .append('<option value="">-- Select Service Engineer --</option>')
                        .prop("disabled", false);

                    $.each(res.data, function (i, admin) {
                        $("#AdminDropdown").append(
                            `<option value="${admin.u_RECID}">
                                ${admin.u_USERNAME}
                            </option>`
                        );
                    });

                } else {
                    $("#AdminDropdown")
                        .append('<option value="">No Service Engineer mapped to this product</option>')
                        .prop("disabled", true);
                }
            },
            error: function () {
                $("#AdminDropdown")
                    .empty()
                    .append('<option value="">Error loading Service Engineer</option>')
                    .prop("disabled", true);
            }
        });
    }

    // Load admins when page loads
    loadAdmins();

    // Optional: reload when product changes
    $("#SelectedProduct").on("change", function () {
        loadAdmins();
    });

    // Store selected admin RECID
    $("#AdminDropdown").on("change", function () {
        $("#CU_ADMINRECID").val($(this).val());
    });

});
    </script>

