    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function confirmProcess(url) {
            Swal.fire({
                title: 'Are you sure?',
                text: "Do you want to process this invoice?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Yes, Process it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = url;
                }
            });
        }

        function confirmUnlock(url) {
            Swal.fire({
                title: 'Are you sure?',
                text: "Do you want to unlock this invoice?",
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#28a745',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Yes, Unlock it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = url;
                }
            });
        }
    </script>
    <script>
        var selectedRecid = 0;

        function openPrintPopup(recid) {
            selectedRecid = recid;

            Swal.fire({
                title: 'Print Invoice',
                html: `
            <div style="font-size:16px">
                <label style="cursor:pointer">
                    <input type="checkbox" id="swalAnnexure" style="margin-right:8px"/>
                    Include Warranty Annexure
                </label>
            </div>
            `,
                icon: 'info',
                showCancelButton: true,
                confirmButtonText: 'Print',
                cancelButtonText: 'Cancel',
                confirmButtonColor: '#3085d6'
            }).then((result) => {
                if (result.isConfirmed) {

                    // ✅ GET VALUE HERE
                    var isAnnexure = document.getElementById('swalAnnexure').checked;

                    var url = '/AccountantCustomerInvoice/ViewInvoicePdf?invoiceRecid='
                        + selectedRecid + '&isAnnexure=' + isAnnexure;

                    window.location.href = url; // ✅ same page
                }
            });
        }
    </script>
    @if (TempData["SuccessMessage"] != null)
