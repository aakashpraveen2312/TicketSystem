    <script>
$(document).ready(function () {

    const selectedAdminFromEdit = '@Model.SIP_ADMINRECID';

    function setWarrantyDate() {

        var selected = $("#SelectedProduct option:selected");

        var duration = selected.attr("data-duration");

        if (!duration) return;

        duration = parseInt(duration);

        if (isNaN(duration) || duration === 0) return;

        var today = new Date();
        today.setMonth(today.getMonth() + duration);

        var formattedDate = today.toISOString().split('T')[0];

        $("#SIP_WARRANTYUPTO").val(formattedDate);
    }

    $("#SelectedProduct").on("change", function () {

        var precid = $(this).val();
        var cmprecid = '@Session["CompanyID"]';
        setWarrantyDate();

        $("#AdminDropdown")
            .prop("disabled", true)
            .empty()
            .append('<option value="">Loading admins...</option>');

        if (!precid) {
            $("#AdminDropdown")
                .empty()
                .append('<option value="">-- Select Admin --</option>');
            return;
        }

        $.ajax({
            url: '@Url.Action("GetProductAdmins", "SalesInvoiceProduct")',
            type: 'GET',
            data: {
                cmprecid: cmprecid,
                precid: precid
            },
            success: function (res) {

                console.log("API response:", res);
                $("#AdminDropdown").empty();

                if (res.status === "Y" && res.data && res.data.length > 0) {

                    $("#AdminDropdown")
                        .append('<option value="">-- Select Admin --</option>')
                        .prop("disabled", false);

                    $.each(res.data, function (i, admin) {

                        //var isSelected = admin.u_RECID == selectedAdminFromEdit;
                        var isSelected =
                            admin.u_RECID.toString() === selectedAdminFromEdit.toString();

                        $("#AdminDropdown").append(
                            $('<option>', {
                                value: admin.u_RECID,
                                text: admin.u_USERNAME,
                                selected: isSelected
                            })
                        );
                    });

                    // 🔑 SET hidden value on load (EDIT MODE)
                    if (selectedAdminFromEdit) {
                        $("#SIP_ADMINRECID").val(selectedAdminFromEdit);
                    }

                } else {
                    $("#AdminDropdown")
                        .append('<option value="">No Admins mapped to this product</option>')
                        .prop("disabled", true);
                }
            },
            error: function () {
                $("#AdminDropdown")
                    .empty()
                    .append('<option value="">Error loading admins</option>')
                    .prop("disabled", true);
            }
        });
    });

    // Single change handler
    $("#AdminDropdown").on("change", function () {
        $("#SIP_ADMINRECID").val($(this).val());
    });

    // 🔥 Auto-load admins on EDIT page
    if ($("#SelectedProduct").val()) {
        $("#SelectedProduct").trigger("change");
    }
});
    </script>

    <script>
        function paginateList(listId, paginationId, rowsPerPage = 3) {

            const list = document.getElementById(listId);
            const items = list.getElementsByTagName("li");
            const pagination = document.getElementById(paginationId);

            let currentPage = 1;
            const totalPages = Math.ceil(items.length / rowsPerPage);

            function showPage(page) {

                currentPage = page;

                for (let i = 0; i < items.length; i++) {
                    items[i].style.display = "none";
                }

                let start = (page - 1) * rowsPerPage;
                let end = start + rowsPerPage;

                for (let i = start; i < end && i < items.length; i++) {
                    items[i].style.display = "list-item";
                }

                renderPagination();
            }

            function renderPagination() {

                pagination.innerHTML = "";

                if (currentPage > 1) {
                    pagination.innerHTML += `<button onclick="show${listId}(${currentPage - 1})">Previous</button>`;
                }

                for (let i = 1; i <= totalPages; i++) {
                    pagination.innerHTML += `<button onclick="show${listId}(${i})">${i}</button>`;
                }

                if (currentPage < totalPages) {
                    pagination.innerHTML += `<button onclick="show${listId}(${currentPage + 1})">Next</button>`;
                }
            }

            window["show" + listId] = showPage;

            showPage(1);
        }

        paginateList("inclusionList", "inclusionPagination");
        paginateList("exclusionList", "exclusionPagination");
    </script>

