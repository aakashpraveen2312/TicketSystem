                        <img src="~/assets/img/ReportImage.png" class="openIcon" style="display:none;width:25px;height:25px;margin-bottom:10px;" />
                        <span class="text nav-text" style="margin-left:15px">REPORTS</span>
                    </li>

                    <li class="nav-link">
