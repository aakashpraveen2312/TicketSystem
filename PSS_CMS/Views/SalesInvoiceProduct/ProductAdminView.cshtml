        i.bi.bi-eye.\-.fill {
            font-size: 17px;
        }
    </style>
</head>

<body>
    <div class="content" style=" overflow-x: hidden!important;">
        <nav class="nav d-flex">
            <div class="p-2 flex-grow-1"> <h3 style="margin-top:10px" class="heading ms-3 adminheadinres">SERVICE MANAGEMENT</h3></div>
            <div class="p-2" style="margin-right:10px"><h4 class="heading adminlogoutres">@Session["UserName"].ToString().ToUpper() - @Session["Role"]</h4></div>
            <div class="p-2 me-3 logout" style="margin-right:10px" data-toggle="tooltip" data-placement="bottom" title="Log out">
                <a href="@Url.Action("Logout", "Login")" class="text-decoration-none" id="logoutlink" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasBottom" aria-controls="offcanvasBottom">
                    <i class='bx bx-log-out' style="font-size:24px;color:red !important;" id="logoutresiconadmin"></i>

                </a>
            </div>

        </nav>
        <div class="row" style="margin-top:10px">
            <div class="col-lg-9">
                <ul class="breadcrumb mt-1" style="margin-bottom:0px!important">
                    <li class="" style="color: #2888bb;text-decoration:none"><a href="@Url.Action("SalesheaderAdminListView", "AccountantCustomerInvoice")">SALES INVOICE ENTRY</a></li>
                    <li>SALES PRODUCT LIST</li>

                </ul>
            </div>
            <div class="col-lg-3" style="display:flex;align-items:end;justify-content:end;">
                @using (Html.BeginForm("List", "SalesInvoiceProduct", FormMethod.Get, new { id = "searchForm" }))
                {
                    <input type="text" id="searchPharse" name="searchPharse" class="inputcustom" placeholder="Search" autocomplete="off" value="@Request["searchPharse"]" style="margin-top:3px; padding-right: 40px;width:100%;" />
                }

                <!-- Add button with icon -->
                @*<a href="@Url.Action("Create", "SalesInvoiceProduct", new {
							SIP_PRECID=Session["SIP_PRECID"] })" class=" ms-3" style="margin-left: 30px;">
                    <img src="~/assets/img/icons8-add-32.png" class="addimg" alt="Add" width="20" height="20" title="Add Product" />
                </a>*@
                @*<a href="@Url.Action("ExcelUserDownload", "AccountantCustomerInvoice")" class="" title="Export as Excel" style="text-decoration:none;">
                        <img src="~/assets/img/Excel image.png" alt="Add" width="30" height="30" />
                    </a>*@

            </div>

        </div>

        <div class="table mt-3 ms-1 me-5" id="ticketTable1">
            @if (Model != null)
            {
                @Html.Grid(Model).Columns(columns =>
           {
               columns.Add(c => c.SerialNumber).Titled("S.No").Css("text-center").SetWidth("20px");
               columns.Add(c => c.ProductName).Titled("Product Name");
               columns.Add(c => c.SIP_PRODUCTSERIALNUMBER).Titled("Product Serial Number");
               columns.Add(c => c.SIP_WARRANTYUPTO)
    .Titled("Warranty Upto")
    .RenderValueAs(c =>
        string.IsNullOrEmpty(c.SIP_WARRANTYUPTO)
        ? ""
        : Convert.ToDateTime(c.SIP_WARRANTYUPTO).ToString("dd-MM-yyyy")
    );
               //columns.Add(c => c.SIP_WARRANTYFREECALLS).Titled("Warranty Free Calls");
               columns.Add(c => c.WARRANTY_STATUS)
     .Titled("Status")
     .Encoded(false)
     .Sanitized(false)
     .RenderValueAs(item =>
         "<span class='badge " +
         (item.WARRANTY_TYPE == "Active"
             ? "bg-success text-center"
             : item.WARRANTY_TYPE == "Going to Expire"
                 ? "bg-warning text-center"
                 : "bg-danger text-center") +
         "'>" +
         item.WARRANTY_STATUS +
         "</span>"
     );

               columns.Add().Titled("Action")
              .Encoded(false)
               .Sanitized(false)
            .RenderValueAs(o =>
            {

                var Viewurl = Url.Action("ProductDetailView", "SalesInvoiceProduct", new { Recid = o.SIP_RECID }, null);
                var ViewiconHtml = "<i class='bx bx-show bx-sm text-success'></i>";
                var ViewlinkHtml = $"<a href='{Viewurl}' title='View'>{ViewiconHtml}</a>";

                var ActionIcons = $"{ViewlinkHtml}" ; 
                return MvcHtmlString.Create($"{ActionIcons}");
            });

           }).WithPaging(10).Sortable(false)
            }
            else
            {
                <div class="alert alert-warning text-center">
                    <b>No Customers are available</b>
                </div>}
            <footer>
                <div class="footer">
                    <div class="flex-container" style="padding-top:5px;padding-left:5px">

                        <div class="flex-item mt-1">
                            <div class="d-flex justify-content-center footerb">
                                <img src="~/assets/img/icons8-add-32.png" alt="Add" width="15" height="15" />
                            </div>&nbsp;- Create
                        </div>

                        <div class="flex-item mt-1">
                            <div class="d-flex justify-content-center footerb">
                                <i style="color:#337ab7" class='bx bxs-pencil bx-sm'> </i>
                            </div>
                            &nbsp;- Edit
                        </div>

                        <div class="flex-item  mt-1">
                            <div class="d-flex justify-content-center footerb">
                                <i class='bx bxs-trash bx-sm red mb-1'> </i>
                            </div>
                            &nbsp;- Delete
                        </div>



                        <div class="flex-item  mt-1">
                            <div class="d-flex justify-content-center footerb">
                                <i class='bi bi-bell bx-sm '> </i>
                            </div>
                            &nbsp;- Follow Ups
                        </div>  <div class="flex-item  mt-1">
                            <div class="d-flex justify-content-center footerb">
                                <i class='bi bi-file-earmark-pdf-fill text-danger bx-sm '> </i>
                            </div>
                            &nbsp;- Warranty PDF
                        </div>
                        <div class="flex-item  mt-1">
                            <div class="d-flex justify-content-center footerb">
                                <i class='bi bi-envelope-check text-primary bx-sm'> </i>
                            </div>
                            &nbsp;- Email (Warranty PDF)
                        </div>
                        <div class="flex-item  mt-1">
                            <div class="d-flex justify-content-center footerb">
                                <img src="~/assets/img/Excel image.png" alt="Add" width="20" height="20" />
                            </div>
                            &nbsp;- Excel Export
                        </div>
                        <div class="flex-item  mt-1">
                            <div class="d-flex justify-content-center footerb">
                                <i class='bx bx-show bx-sm text-success'> </i>
                            </div>
                            &nbsp;- View
                        </div>
                    </div>
                </div>
            </footer>
        </div>




    </div>


    <div class="offcanvas offcanvas-bottom" tabindex="-1" id="offcanvasBottom" aria-labelledby="offcanvasBottomLabel" style="height: 150px;">
        <div class="offcanvas-header">
            <h5 class="offcanvas-title text-align-center" id="offcanvasBottomLabel"></h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body d-flex flex-column justify-content-center align-items-center">
            <h4>Are you sure you want to log out?</h4>
        </div>
        <div class="offcanvas-footer d-flex justify-content-center">
            <input type="button" class="btncolorsubmit me-3" id="confirmLogoutBtn" value="Confirm" tabindex="1">
            <input type="button" class="btncolorcancel" data-bs-dismiss="offcanvas" value="Cancel" tabindex="2">
        </div>
    </div>
    <div id="preloader2"></div>
    <!-- LogOut JS -->
    <script src="~/Scripts/Logoutjs.js"></script>



    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script src="~/Scripts/Fordelete.js"></script>
    <script>
        function DownloadWarrantyPDF(id) {

            Swal.fire({
                title: 'Processing...',
                text: 'Generating Warranty PDF',
                allowOutsideClick: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            $.ajax({
                url: '/AccountantCustomerInvoice/WarrantyPDF',
                type: 'POST',
                data: { CU_RECID: id },
                xhrFields: {
                    responseType: 'blob'
                },
                success: function (data) {

                    var blob = new Blob([data], { type: "application/pdf" });

                    var link = document.createElement('a');
                    link.href = window.URL.createObjectURL(blob);
                    link.download = "Warranty.pdf";
                    document.body.appendChild(link);
                    link.click();
                    document.body.removeChild(link);

                    Swal.close();
                },
                error: function () {

                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'Failed to download PDF'
                    });

                }
            });
        }
    </script>

    <script>
        function SendWarrantyEmail(id, email) {

            Swal.fire({
                title: 'Processing...',
                text: 'Sending Warranty PDF to Email',
                allowOutsideClick: false,
                showConfirmButton: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            $.ajax({
                url: '/AccountantCustomerInvoice/WarrantyPDFToEmail',
                type: 'POST',
                data: {
                    CU_RECID: id,
                    Email: email
                },
                success: function (response) {

                    Swal.close();

                    if (response.status === "Y") {

                        Swal.fire({
                            icon: 'success',
                            title: 'Success',
                            text: response.message
                        });

                    } else {

                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: response.message
                        });

                    }

                },
                error: function () {

                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'Something went wrong'
                    });

                }
            });
        }
    </script>
</body>
</html>


