                        <div class="d-flex justify-content-center footerb">
                            <i class='bi bi-file-earmark-pdf-fill text-danger bx-sm '> </i>
                        </div>
                        &nbsp;- Warranty PDF
                    </div>  
                    <div class="flex-item  mt-1">
                        <div class="d-flex justify-content-center footerb">
                            <i class='bi bi-envelope-check text-primary bx-sm'> </i>
                        </div>
                        &nbsp;- Email (Warranty PDF)
                    </div>  
                    <div class="flex-item  mt-1">
                        <div class="d-flex justify-content-center footerb">
                            <img src="~/assets/img/Excel image.png" alt="Add" width="20" height="20" />
                        </div>
                        &nbsp;- Excel Export
                    </div>
                </div>
            </div>
        </footer>
        </div>


      

