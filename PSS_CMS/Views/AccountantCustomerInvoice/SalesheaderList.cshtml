        Swal.fire({
            icon: 'error',
            title: 'Error',
            text: '@TempData["ErrorMessage"]',
            confirmButtonColor: '#d33'
        });
        </script>
    }
    <script src="~/Scripts/Fordelete.js"></script>
    <script>
        function DownloadWarrantyPDF(id) {

            Swal.fire({
                title: 'Processing...',
                text: 'Generating Warranty PDF',
                allowOutsideClick: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            $.ajax({
                url: '/AccountantCustomerInvoice/WarrantyPDF',
                type: 'POST',
                data: { CU_RECID: id },
                xhrFields: {
                    responseType: 'blob'
                },
                success: function (data) {

                    var blob = new Blob([data], { type: "application/pdf" });

                    var link = document.createElement('a');
                    link.href = window.URL.createObjectURL(blob);
                    link.download = "Warranty.pdf";
                    document.body.appendChild(link);
                    link.click();
                    document.body.removeChild(link);

                    Swal.close();
                },
                error: function () {

                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'Failed to download PDF'
                    });

                }
            });
        }
    </script>

    <script>
        function SendWarrantyEmail(id, email) {

            Swal.fire({
                title: 'Processing...',
                text: 'Sending Warranty PDF to Email',
                allowOutsideClick: false,
                showConfirmButton: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            $.ajax({
                url: '/AccountantCustomerInvoice/WarrantyPDFToEmail',
                type: 'POST',
                data: {
                    CU_RECID: id,
                    Email: email
                },
                success: function (response) {

                    Swal.close();

                    if (response.status === "Y") {

                        Swal.fire({
                            icon: 'success',
                            title: 'Success',
                            text: response.message
                        });

                    } else {

                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: response.message
                        });

                    }

                },
                error: function () {

                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'Something went wrong'
                    });

                }
            });
        }
    </script>
</body>
