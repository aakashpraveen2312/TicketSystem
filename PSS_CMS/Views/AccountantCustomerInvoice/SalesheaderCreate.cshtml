    <script>
        function isNumberKey(evt) {
            var charCode = (evt.which) ? evt.which : evt.keyCode;

            // Allow only numbers (0-9)
            if (charCode < 48 || charCode > 57) {
                return false;
            }
            return true;
        }

        // Extra safety: prevent paste of non-numeric or more than 10 digits
        document.getElementById("CU_MOBILENO").addEventListener("input", function () {
            this.value = this.value.replace(/\D/g, '').slice(0, 10);
        });
    </script>

