        <div class="table mt-3 ms-1 me-5" id="ticketTable1">
            @if (Model != null)
            {
                @Html.Grid(Model).Columns(columns =>
           {
               columns.Add(c => c.SerialNumber).Titled("S.No").Sortable(true).Css("text-right").SetWidth("80px");

               columns.Add(c => c.CT_CODE).Titled("Code");

               columns.Add(c => c.CT_CUSTOMERNAME).Titled("Customer Name");
               columns.Add(c => c.CT_EMAIL).Titled("Email");
               columns.Add(c => c.CT_MOBILE).Titled("Mobile");
               columns.Add(c => c.TotalProductAmount).Titled("Contract Amount").Css("text-right");

               //columns.Add(c => c.FromDate).Titled("From Date");
               //columns.Add(c => c.ToDate).Titled("To Date");

               columns.Add(c => c.CT_SORTORDER).Titled("Sort").SetWidth("80px").Css("text-right");

               columns.Add().Titled("Action").SetWidth("150px")
               .Encoded(false)
               .Sanitized(false)
               .RenderValueAs(o =>
               {
                   var Editurl = Url.Action("EditContract", "Contract", new { CT_RECID = o.CT_RECID, CT_CONTRACTREFERENCENUMBER = o.CT_CUSTOMERNAME });
                   var ServiceProductsurl = Url.Action("ContractProductList", "Contract", new { CT_RECID = o.CT_RECID, CT_PRECID = o.CT_PRECID, ProductName = o.ProductName, CT_URECID = o.CT_URECID, CT_EXISTINGUSER = o.CT_EXISTINGUSER });
                   var Deleteurl = Url.Action("DeleteContract", "Contract", new { id = o.CT_RECID });


                   var EditiconHtml = "<i class='bx bxs-pencil bx-sm'></i>";
                   var ServiceProductsiconHtml = "<i class='bx bx-cart-alt bx-sm'></i> ";
                   var DeleteiconHtml = "<i class='bx bxs-trash bx-sm red'></i>";


                   var EditlinkHtml = $"<a href='{Editurl}' data-toggle='tooltip' data-placement='top' title='Edit'>{EditiconHtml}</a>";
                   var ServiceProductslinkHtml = $"<a href='{ServiceProductsurl}' data-toggle='tooltip' data-placement='top' title='Services'>{ServiceProductsiconHtml}</a>";
                   var DeletelinkHtml = $"<a href='{Deleteurl}' data-toggle='tooltip' data-placement='top' title='Delete' onclick='return confirmDelete(this);'>{DeleteiconHtml}</a>";



                   var Inclusionurl = Url.Action("List", "ContractInclusion", new { CT_RECID = o.CT_RECID, CT_CONTRACTREFERENCENUMBER = o.CT_CONTRACTREFERENCENUMBER }, null);
                   var InclusioniconHtml = "<i class='bi bi-plus-circle-dotted'></i>";
                   var InclusionlinkHtml = $"<a href='{Inclusionurl}' data-toggle='tooltip' data-placement='top' title='Inclusion'>{InclusioniconHtml}</a>";

                   var Exclusionurl = Url.Action("List", "ContractExclusion", new { CT_RECID = o.CT_RECID, CT_CONTRACTREFERENCENUMBER = o.CT_CONTRACTREFERENCENUMBER }, null);
                   var ExclusioniconHtml = "<i class='bi bi-dash-circle-dotted'></i>";
                   var ExclusionlinkHtml = $"<a href='{Exclusionurl}' data-toggle='tooltip' data-placement='top' title='Exclusion'>{ExclusioniconHtml}</a>";

                   var downloadpdfUrl = Url.Action("ContractInvoice", "Contract", new { CT_URECID = o.CT_URECID, CT_CRECID = o.CT_CRECID });
                   var downloadpdfIconHtml = "<i class='bi bi-file-earmark-pdf fs-4 text-danger'></i>";
                   var downloadpdflinkHtml = $"<a href='javascript:void(0);' onclick=\"downloadPdfAjax('{downloadpdfUrl}')\" data-toggle='tooltip' title='Download PDF'>{downloadpdfIconHtml}</a>";

                   var extraSpaces = "&nbsp;&nbsp;";
                   return MvcHtmlString.Create($"{EditlinkHtml}{extraSpaces}{DeletelinkHtml}{extraSpaces}{ServiceProductslinkHtml}{extraSpaces}{downloadpdflinkHtml}");
               });

           }).WithPaging(10).Sortable(true)
            }
            else
            {
                <div class="alert alert-warning text-center">
                    <b>No contracts are available</b>
                </div>}

