    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script src="~/Scripts/Fordelete.js"></script>
    <script>
        function downloadPdfAjax(url) {
            // Show a SweetAlert2 loading popup
            Swal.fire({
                title: 'Processing...',
                text: 'Your PDF is being prepared.',
                allowOutsideClick: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            $.ajax({
                url: url,
                type: 'POST',
                xhrFields: {
                    responseType: 'blob' // important for PDF
                },
                success: function (data, status, xhr) {
                    // Close the loading popup
                    Swal.close();

                    var blob = new Blob([data], { type: 'application/pdf' });
                    var link = document.createElement('a');
                    link.href = window.URL.createObjectURL(blob);

                    // Optional: get filename from response header
                    var disposition = xhr.getResponseHeader('Content-Disposition');
                    var fileName = "Invoice.pdf";
                    if (disposition && disposition.indexOf('filename=') !== -1) {
                        fileName = disposition.split('filename=')[1].replace(/"/g, '');
                    }

                    link.download = fileName;
                    document.body.appendChild(link);
                    link.click();
                    document.body.removeChild(link);
                },
                error: function () {
                    // Close the loading popup and show error
                    Swal.fire({
                        icon: 'error',
                        title: 'Oops...',
                        text: 'Failed to download PDF.'
                    });
                }
            });
        }
    </script>
</body>
