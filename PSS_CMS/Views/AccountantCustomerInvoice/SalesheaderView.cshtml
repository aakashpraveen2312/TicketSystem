                            @Html.EditorFor(model => model.CU_CONTACTPERSONMOBILE3, new { htmlAttributes = new { @class = "form-control textboxcolors", autocomplete = "off", @readonly = "readonly" } })
                        </div>
                        <div class="mb-3">
                            @Html.LabelFor(model => model.CU_CONTACTPERSONDESIGINATION3, new { @class = "labels" })
                            @Html.EditorFor(model => model.CU_CONTACTPERSONDESIGINATION3, new { htmlAttributes = new { @class = "form-control textboxcolors", autocomplete = "off", @readonly = "readonly" } })
                        </div>
                        <div class="mb-3 form-check">
                            @Html.CheckBoxFor(model => model.CU_CONTACTACCESS3_BOOL, new { @class = "form-check-input", disabled = "disabled" })
                            <label class="form-check-label">Access Credential</label>
                        </div>
                        <div class="mb-3 d-flex justify-content-end">
                            @*<input type="submit" value="Save" class="submitbuttons me-3" tabindex="" id="savebutton" />*@
                            <input type="button" value="Cancel" class="cancelbuttons" tabindex="" id="" onclick="window.location.href='@Url.Action("SalesheaderList", "AccountantCustomerInvoice", new {CU_CTRECID=Session["RECID"],Name=Session["ContractName"],CT_PRECID=Session["CT_PRECID"],CT_CONTRACTAMOUNT=Session["ContractAmount"]})'" />

