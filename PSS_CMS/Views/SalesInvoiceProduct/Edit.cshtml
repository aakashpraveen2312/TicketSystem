                            @{
                                var ProductList = ViewBag.Product as IEnumerable<SelectListItem>;
                                var durationMap = ViewBag.ProductDurationList as Dictionary<int, int>;
                            }

                            @if (ProductList != null && ProductList.Any())
                            {
                                var modifiedProductList = new List<SelectListItem>(ProductList);

                                // Add default option
                                if (modifiedProductList.Count > 1)
                                {
                                    modifiedProductList.Insert(0, new SelectListItem
                                    {
                                        Text = "-- Select Product --",
                                        Value = ""
