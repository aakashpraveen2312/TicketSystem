        <div class="table mt-3 ms-1 me-5" id="ticketTable1">
            @if (Model != null)
            {
                @Html.Grid(Model).Columns(columns =>
           {
               columns.Add(c => c.SerialNumber).Titled("S.No").Css("text-left").SetWidth("20px");
               columns.Add(c => c.SIH_INVOICENO).Titled("Invoice Number").SetWidth("80px");
               columns.Add(c => c.SIH_INVOICEDATE)
   .Titled("Invoice Date")
   .RenderValueAs(c =>
       string.IsNullOrEmpty(c.SIH_INVOICEDATE)
       ? ""
       : Convert.ToDateTime(c.SIH_INVOICEDATE).ToString("dd-MM-yyyy")
   )
   .SetWidth("80px");
               columns.Add(c => c.SIH_INVOICEAMOUNT)
        .Titled("Invoice Net Amount")
        .SetWidth("180px")
        .Css("text-right")
       .RenderValueAs(c => String.Format("{0:N2}", c.SIH_INVOICEAMOUNT));
               columns.Add().Titled("Action")
               .SetWidth("180px")
              .Encoded(false)
              .Css("text-center")
               .Sanitized(false)
            .RenderValueAs(o =>
            {
                var isProcessed = o.SIH_STATUS == "P";

                var Editurl = Url.Action("SalesheaderEdit", "AccountantCustomerInvoice", new { Recid = o.SIH_RECID }, null);
                var Viewurl = Url.Action("SalesheaderView", "AccountantCustomerInvoice", new { Recid = o.SIH_RECID }, null);

                var Processurl = Url.Action("ProcessInvoice", "AccountantCustomerInvoice", new { Recid = o.SIH_RECID }, null);
                var Unlockurl = Url.Action("UnlockInvoice", "AccountantCustomerInvoice", new { Recid = o.SIH_RECID }, null);

                var EditiconHtml = "<i class='bx bxs-pencil bx-sm'></i>";
                var ViewiconHtml = "<i class='bx bx-show bx-sm text-success'></i>";
                var ProcessiconHtml = "<i class='bx bx-check-circle bx-sm text-success'></i>";
                var UnlockiconHtml = "<i class='bx bx-lock-open bx-sm text-danger'></i>";

                var EditlinkHtml = $"<a href='{Editurl}' title='Edit'>{EditiconHtml}</a>";
                var ViewlinkHtml = $"<a href='{Viewurl}' title='View'>{ViewiconHtml}</a>";

                var ProcesslinkHtml = $"<a href='javascript:void(0);' onclick='confirmProcess(\"{Processurl}\")' title='Process'>{ProcessiconHtml}</a>";
                var UnlocklinkHtml = $"<a href='javascript:void(0);' onclick='confirmUnlock(\"{Unlockurl}\")' title='Unlock'>{UnlockiconHtml}</a>";
                var ProductNotifyurl = Url.Action("List", "SalesInvoiceProduct",
                    new { SalesinvoiceRecID = o.SIH_RECID, customerid = o.SIH_CURECID, status = o.SIH_STATUS ,invoicedate = o.SIH_INVOICEDATE});

                var ProductNotifyIconHtml = "<i class='bi bi-box-seam bx-sm'></i>";
                var ProductNotifylinkHtml = $"<a href='{ProductNotifyurl}' title='View Products'>{ProductNotifyIconHtml}</a>";

                var Printurl = Url.Action("ViewInvoicePdf", "AccountantCustomerInvoice", new { invoiceRecid = o.SIH_RECID }, null);
                var PrinticonHtml = "<i class='bx bx-printer bx-sm text-primary'></i>";
                var PrintlinkHtml = $"<a href='javascript:void(0);' onclick='openPrintPopup({o.SIH_RECID})' title='Print'>{PrinticonHtml}</a>";

                var Paymenturl = Url.Action("PaymentList", "SalesInvoiceProduct", new { SalesinvoiceRecID = o.SIH_RECID, Invoiceamount =  o.SIH_INVOICEAMOUNT, Invoicenumber = o.SIH_INVOICENO, Invoicedate = o.SIH_INVOICEDATE });
                var PaymenticonHtml = "<i class='bi bi-currency-rupee fs-4 text-success'></i>";
                var PaymentlinkHtml = $"<a href='{Paymenturl}' title='Payment'>{PaymenticonHtml}</a>";

                var Deleteurl = Url.Action("SalesheaderDelete", "AccountantCustomerInvoice", new { Recid = o.SIH_RECID }, null);
                var DeleteiconHtml = "<i class='bx bxs-trash bx-sm red'></i>";
                var DeletelinkHtml = $"<a href='{Deleteurl}' title='Delete' onclick='return confirmDelete(this);'>{DeleteiconHtml}</a>";

                var extraSpaces = "&nbsp;";

                // 🔥 FINAL CONDITION
                var ActionIcons = isProcessed
                    ? $"{ViewlinkHtml}{extraSpaces}{PrintlinkHtml}{extraSpaces}{PaymentlinkHtml}"   // Processed
                    : $"{EditlinkHtml}{extraSpaces}{ProcesslinkHtml}"; // Not Processed

                return MvcHtmlString.Create($"{ActionIcons}{extraSpaces}{DeletelinkHtml}{extraSpaces}{ProductNotifylinkHtml}");
            });

           }).WithPaging(10).Sortable(false)
