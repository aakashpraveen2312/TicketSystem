            </div>
            <div class="col-lg-3" style="display:flex;align-items:end;justify-content:end;">
                @using (Html.BeginForm("List", "AccountantCustomerInvoice", FormMethod.Get, new { id = "searchForm" }))
                {
                    <input type="text" id="searchPharse" name="searchPharse" class="inputcustom" placeholder="Search" autocomplete="off" value="@Request["searchPharse"]" style="margin-top:3px; padding-right: 40px;width:100%;" />
                }

                <!-- Add button with icon -->
                <a href="@Url.Action("Create", "AccountantCustomerInvoice", new { CU_CTRECID=Session["RECID"],
							Name=Session["ContractName"],
							CT_PRECID=Session["CT_PRECID"],
							CT_CONTRACTAMOUNT=Session["ContractAmount"] })" class=" ms-3" style="margin-left: 30px;">
                    <img src="~/assets/img/icons8-add-32.png" class="addimg" alt="Add" width="20" height="20" title="Add User" />
                </a>

                <a href="@Url.Action("ExcelUserDownload", "AccountantCustomerInvoice")" class="" title="Export as Excel" style="text-decoration:none;">
                    <img src="~/assets/img/Excel image.png" alt="Add" width="30" height="30" />
                </a>

            </div>

        </div>

        <div class="table mt-3 ms-1 me-5" id="ticketTable1">
            @if (Model != null)
            {
                @Html.Grid(Model).Columns(columns =>
           {
               columns.Add(c => c.SerialNumber).Titled("S.No").Css("text-right").SetWidth("20px");
               columns.Add()
     .Titled("Customer")
     .SetWidth("180px")
     .RenderValueAs(c => $"{c.CU_CODE} - {c.CU_NAME}");
               columns.Add(c => c.CU_EMAIL).Titled("Email ID").SetWidth("250px");
               columns.Add(c => c.CU_INVOICENO).Titled("Invoice Number");
               columns.Add(c => c.CU_INVOICEAMOUNT)
        .Titled("Invoice Amount")
        .Css("text-right")
       .RenderValueAs(c => String.Format("{0:N0}", c.CU_INVOICEAMOUNT));
               columns.Add(c => c.CU_INVOICEDATEDATE).Titled("Invoice Date");
               columns.Add(c => c.CU_WARRANTYUPTODATE).Titled("Warranty Upto");
               columns.Add(c => c.WARRANTY_STATUS)
     .Titled("Status")
     .Encoded(false)
     .Sanitized(false)
     .RenderValueAs(item =>
         "<span class='badge " +
         (item.WARRANTY_TYPE == "Active"
             ? "bg-success text-center"
             : item.WARRANTY_TYPE == "Going to Expire"
                 ? "bg-warning text-center"
                 : "bg-danger text-center") +
         "'>" +
         item.WARRANTY_STATUS +
         "</span>"
     );

               columns.Add().Titled("Action")
              .Encoded(false)
               .Sanitized(false)
            .RenderValueAs(o =>
            {

                var Editurl = Url.Action("Edit", "AccountantCustomerInvoice", new { Recid = o.CU_RECID, Name = o.CU_NAME }, null);
                var EditiconHtml = "<i class='bx bxs-pencil bx-sm'></i>";
                var EditlinkHtml = $"<a href='{Editurl}' data-toggle='tooltip' data-placement='top' title='Edit'>{EditiconHtml}</a>";


                var CustomerNotifyurl = Url.Action("List", "CustomerNotification", new { CustomerRecID = o.CU_RECID, Name = o.CU_NAME,InvoiceNo = o.CU_INVOICENO});
                var CustomerNotifyIconHtml = "<i class='bi bi-bell bx-sm'></i>";
                var CustomerNotifylinkHtml = $"<a href='{CustomerNotifyurl}' data-toggle='tooltip' data-placement='top' title='Follow-up'>{CustomerNotifyIconHtml}</a>";

                var Deleteurl = Url.Action("Delete", "AccountantCustomerInvoice", new { Recid = o.CU_RECID }, null);
                var DeleteiconHtml = "<i class='bx bxs-trash bx-sm red'></i>";
                var DeletelinkHtml = $"<a href='{Deleteurl}' data-toggle='tooltip' data-placement='top' title='Delete' onclick='return confirmDelete(this);'>{DeleteiconHtml}</a>";

                var PDFurl = Url.Action("WarrantyPDF", "AccountantCustomerInvoice", new { CU_RECID = o.CU_RECID }, null);
                var PDFiconHtml = "<i class='bi bi-file-earmark-pdf-fill text-danger'></i>";
                var PDFlinkHtml = $"<a href='javascript:void(0);' onclick='DownloadWarrantyPDF({o.CU_RECID})' title='Warranty PDF'>{PDFiconHtml}</a>";



                var Emailurl = Url.Action("", "", new { Recid = o.CU_RECID, Email = o.CU_EMAIL }, null);
                var EmailiconHtml = "<i class='bi bi-envelope-check text-primary'></i>";
                var EmaillinkHtml = $"<a href='javascript:void(0);' onclick='SendWarrantyEmail({o.CU_RECID},\"{o.CU_EMAIL}\")' title='Email'>{EmailiconHtml}</a>";


                var InvoicePDFurl = Url.Action("WarrantyPDF", "AccountantCustomerInvoice", new { CU_URECID = o.CU_URECID }, null);
                var InvoicePDFiconHtml = "<i class='bi bi-file-earmark-pdf-fill text-danger'></i>";
                var InvoicePDFlinkHtml = $"<a href='javascript:void(0);' onclick='DownloadInvoicePDF({o.CU_URECID})' title='Warranty PDF'>{InvoicePDFiconHtml}</a>";


                var extraSpaces2 = "&nbsp;";
                return MvcHtmlString.Create($"{EditlinkHtml}{extraSpaces2}{DeletelinkHtml}{extraSpaces2}{CustomerNotifylinkHtml}{extraSpaces2}{PDFlinkHtml}{extraSpaces2}{EmaillinkHtml}");
            });

           }).WithPaging(10).Sortable(false)
            }
            else
            {
                <div class="alert alert-warning text-center">
                    <b>No Customers are available</b>
                </div>}
